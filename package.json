{
  "name": "git-tag-generate",
  "homepage": "https://github.com/ddniel16/git-tag-generate",
  "version": "1.2.1",
  "license": "GPL-3.0",
  "author": {
    "name": "ddniel16",
    "url": "https://github.com/ddniel16"
  },
  "type": "module",
  "bin": {
    "gtg": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "preferGlobal": true,
  "keywords": [
    "git",
    "tag",
    "git-tag-generate",
    "version",
    "release",
    "git-tag",
    "semver",
    "cli",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddniel16/git-tag-generate.git"
  },
  "scripts": {
    "clean": "node -e \"try { require('fs').rmSync('dist', { recursive: true, force: true }) } catch(e){}\"",
    "build": "node --run clean && node --run validate && node esbuild.config.mjs",
    "validate": "node --run lint && node --run type-check && node --run format",
    "postbuild": "chmod +x dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "link": "pnpm link --global",
    "unlink": "pnpm unlink --global",
    "preversion": "node --run test && node --run build",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "chalk": "^5.6.2",
    "i18next": "^26.0.3",
    "i18next-fs-backend": "^2.6.3",
    "semver": "^7.7.4",
    "simple-git": "^3.35.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "vite>esbuild": "0.28.0"
      },
      "ignoreMissing": [
        "@emnapi/core",
        "@emnapi/runtime"
      ]
    }
  }
}
